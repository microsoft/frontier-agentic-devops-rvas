{
  "name": "Frontier GitHub Platform Hackathon — All-in-One",

  // Lightweight official Ubuntu base (~a few hundred MB vs. ~10GB for universal:2).
  // Every tool is layered on via Dev Container Features so the image stays small and
  // each version is explicitly pinned. Jammy (22.04 LTS) for broad package support.
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",

  // Dev Container Features provide the full union of tooling needed across all four
  // modules (GHEC, GHAS, GHAW, SRE Agent).
  "features": {
    // gh CLI — used by every module. Pinned feature so participants get a known-good build.
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    // Node 22 (+ npm) — required by the SRE Agent sample app and OWASP Juice Shop.
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    // Python 3.12 — a handful of GHEC/GHAW challenges use small Python helpers.
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    // Azure CLI — SRE Agent module (`az login`, resource management). Bicep is installed
    // on top of this in postCreate.sh (`az bicep install`).
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest"
    },
    // Docker-in-Docker — GHAS runs OWASP Juice Shop; some GHEC/GHAS steps use containers.
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },

  // base:ubuntu ships a non-root `vscode` user by default.
  "remoteUser": "vscode",

  // Installs gh-aw, Bicep, and runs the environment doctor. Runs once after create.
  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  // Module sample apps (Juice Shop, Contoso Claims sample-app) listen on 3000.
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Module app",
      "onAutoForward": "notify"
    }
  },

  // AI Engine API keys (for gh-aw / agentic workflows) — set as Codespace secrets at
  // github.com/settings/codespaces to make them available in every Codespace:
  //   ANTHROPIC_API_KEY (Claude), OPENAI_API_KEY (Codex), GEMINI_API_KEY (Gemini).
  // GitHub Copilot is configured automatically if your account has a Copilot subscription.
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-github-actions",
        "GitHub.vscode-codeql",
        "ms-azuretools.vscode-bicep",
        "redhat.vscode-yaml",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "files.associations": {
          "*.lock.yml": "github-actions-workflow"
        }
      }
    }
  }
}
